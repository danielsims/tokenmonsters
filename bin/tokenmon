#!/usr/bin/env bash
# tokenmon — start the daemon + TUI, with smart terminal detection

DIR="$(cd "$(dirname "$0")/.." && pwd)"
export TOKENMON_SOCKET="/tmp/tokenmon-$(id -u).sock"

# ── Find bun ─────────────────────────────────────────────────────────
if command -v bun &>/dev/null; then
  BUN="$(command -v bun)"
elif [ -x "${HOME}/.bun/bin/bun" ]; then
  BUN="${HOME}/.bun/bin/bun"
else
  echo "Error: Bun runtime not found."
  echo ""
  echo "Install it with:  curl -fsSL https://bun.sh/install | bash"
  exit 1
fi

# ── Terminal detection ────────────────────────────────────────────────
TIER1_TERMINALS="ghostty alacritty wezterm kitty"

is_tier1() {
  local prog
  prog="$(echo "${TERM_PROGRAM:-}" | tr '[:upper:]' '[:lower:]')"
  for t in $TIER1_TERMINALS; do
    [ "$prog" = "$t" ] && return 0
  done
  # kitty sets TERM=xterm-kitty instead of TERM_PROGRAM
  [ "$(echo "${TERM:-}" | tr '[:upper:]' '[:lower:]')" = "xterm-kitty" ] && return 0
  return 1
}

# ── Ghostty launcher ─────────────────────────────────────────────────
find_ghostty() {
  if command -v ghostty &>/dev/null; then
    echo "ghostty"
  elif [ -x "/Applications/Ghostty.app/Contents/MacOS/ghostty" ]; then
    echo "/Applications/Ghostty.app/Contents/MacOS/ghostty"
  fi
}

launch_in_ghostty() {
  local ghostty
  ghostty="$(find_ghostty)"
  if [ -z "$ghostty" ]; then
    echo "Error: Ghostty not found. Install it from https://ghostty.org"
    exit 1
  fi
  TOKEMON_WINDOW=1 exec "$ghostty" --title="Token Monsters" -e "$0"
}

# ── Game runner ───────────────────────────────────────────────────────
run_game() {
  cleanup() {
    if [ -n "$DAEMON_PID" ] && kill -0 "$DAEMON_PID" 2>/dev/null; then
      kill "$DAEMON_PID" 2>/dev/null
      wait "$DAEMON_PID" 2>/dev/null
    fi
    rm -f "$TOKENMON_SOCKET"
  }
  trap cleanup EXIT INT TERM

  # Start daemon in background
  "$BUN" run "$DIR/daemon/index.ts" &>/dev/null &
  DAEMON_PID=$!

  # Brief pause for socket to come up
  sleep 0.3

  # Launch TUI (foreground)
  "$BUN" run "$DIR/src/index.tsx"
}

# ── Main ──────────────────────────────────────────────────────────────
if [ "$1" = "--force" ]; then
  run_game
elif [ "$1" = "--launch" ]; then
  launch_in_ghostty
elif is_tier1 || [ "${TOKEMON_WINDOW:-}" = "1" ]; then
  run_game
else
  # Not in a supported terminal — try to auto-launch in Ghostty
  ghostty="$(find_ghostty)"
  if [ -n "$ghostty" ]; then
    TOKEMON_WINDOW=1 exec "$ghostty" --title="Token Monsters" -e "$0"
  fi
  echo "tokenmon requires a GPU-accelerated terminal for 3D rendering."
  echo ""
  echo "Supported: Ghostty, Alacritty, Kitty, WezTerm"
  echo ""
  echo "  tokenmon --force   Run anyway in this terminal"
  exit 1
fi
